{
  "compilerOptions": {
    "lib": [
      "dom",
      "dom.iterable",
      "esnext"
    ],
    "allowJs": true,
    "noEmit": true,
    "esModuleInterop": true,
    "module": "esnext",
    "moduleResolution": "bundler",
    "resolveJsonModule": true,
    "isolatedModules": true,
    "jsx": "preserve",
    "incremental": true,
    "noEmitOnError": false,
    // This will allow emitting even if there are errors
    "strict": false,
    // Disables strict type checking
    "noUnusedLocals": false,
    // Disables error for unused variables
    "noUnusedParameters": false,
    // Disables error for unused parameters
    "noImplicitAny": false,
    // Allows `any` type without error
    "skipLibCheck": true,
    // Skips type checking of declaration files
    "plugins": [
      {
        "name": "next"
      }
    ],
    "paths": {
      "@/*": [
        "./*"
      ]
    }
  },
  "include": [
    "next-env.d.ts",
    "**/*.ts",
    "**/*.tsx",
    ".next/types/**/*.ts"
  ],
  "exclude": [
    "node_modules"
  ]
}
